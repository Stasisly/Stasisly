{
  "title": "Safe smoke-test result",
  "type": "object",
  "additionalProperties": false,
  "required": ["testId", "status", "safeResultCategory", "durationBucket", "cleanupStatus", "cleanupCounts", "remoteSkipGateStatus", "corsValidationStatus", "dirtyRunBlockerStatus", "evidenceReference"],
  "properties": {
    "testId": {"type": "string", "minLength": 1},
    "status": {"enum": ["NOT_STARTED", "PREPARED", "AUTHORIZED", "EXECUTED", "PASSED", "FAILED", "ROLLED_BACK"]},
    "safeResultCategory": {"enum": ["NOT_RUN", "PASSED_CLEAN", "FAILED_CLEAN", "FAILED_DIRTY_BLOCKING"]},
    "durationBucket": {"enum": ["NOT_MEASURED", "UNDER_10_SECONDS", "UNDER_1_MINUTE", "ONE_TO_FIVE_MINUTES", "OVER_FIVE_MINUTES"]},
    "cleanupStatus": {"enum": ["NOT_REQUIRED", "NOT_STARTED", "PASSED", "FAILED"]},
    "cleanupCounts": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"type": "integer", "minimum": 0}},
    "remoteSkipGateStatus": {"enum": ["NOT_ENABLED", "READY", "BLOCKED"]},
    "corsValidationStatus": {"enum": ["UNASSIGNED", "PASSED", "FAILED"]},
    "dirtyRunBlockerStatus": {"enum": ["CLEAR", "BLOCKED"]},
    "evidenceReference": {"type": "string", "minLength": 1}
  }
}
