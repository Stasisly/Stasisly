{
  "title": "Deployment evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["environment", "projectIdentifier", "commitSha", "operatorReference", "founderApprovalReference", "migrationInventoryVersion", "functionInventoryVersion", "configurationInventoryVersion", "testResultSummary", "timestampStatus", "rollbackReference", "resultStatus", "fixtureSetupStatus", "fixtureNamespaceReference", "cleanupStatus", "cleanupCounts", "remoteSkipGateStatus", "corsValidationStatus", "dirtyRunBlockerStatus"],
  "properties": {
    "environment": {"const": "development"},
    "projectIdentifier": {"type": "string", "minLength": 1},
    "commitSha": {"type": "string", "minLength": 1},
    "operatorReference": {"type": "string", "minLength": 1},
    "founderApprovalReference": {"type": "string", "minLength": 1},
    "migrationInventoryVersion": {"type": "string", "minLength": 1},
    "functionInventoryVersion": {"type": "string", "minLength": 1},
    "configurationInventoryVersion": {"type": "string", "minLength": 1},
    "testResultSummary": {"type": "string", "minLength": 1},
    "timestampStatus": {"type": "string", "minLength": 1},
    "rollbackReference": {"type": "string", "minLength": 1},
    "resultStatus": {"enum": ["NOT_STARTED", "PREPARED", "AUTHORIZED", "EXECUTED", "PASSED", "FAILED", "ROLLED_BACK"]},
    "fixtureSetupStatus": {"enum": ["NOT_STARTED", "PASSED", "FAILED"]},
    "fixtureNamespaceReference": {"type": "string", "minLength": 1},
    "cleanupStatus": {"enum": ["NOT_STARTED", "PASSED", "FAILED"]},
    "cleanupCounts": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"type": "integer", "minimum": 0}},
    "remoteSkipGateStatus": {"enum": ["NOT_ENABLED", "READY", "BLOCKED"]},
    "corsValidationStatus": {"enum": ["UNASSIGNED", "PASSED", "FAILED"]},
    "dirtyRunBlockerStatus": {"enum": ["CLEAR", "BLOCKED"]}
  }
}
