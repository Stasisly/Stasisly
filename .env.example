# Stasisly environment template
#
# This file is safe to commit because it contains only empty values or safe
# defaults. Copy it locally to `.env` when you need local values.
#
# SECURITY RULES
# - `.env.example` can be committed to the repository.
# - `.env` is the real local file and must never be committed.
# - Do not paste `service_role` keys here.
# - Do not paste JWT secrets here.
# - Do not paste access tokens here.
# - Do not paste refresh tokens here.
# - Do not paste connection strings with passwords here.
# - Do not paste production keys here.
# - Do not use real user, health, chat, payment, file or production data.
# - Remote Supabase, real auth and real data remain blocked until explicitly
#   approved by ADR gates.

# Runtime mode.
# Current supported values in code: local, demo, development, staging,
# backendReal, production.
# `backendReal` is legacy/transitional. Demo is the safe default.
APP_MODE=demo

# Supabase configuration.
# Current Flutter code reads SUPABASE_URL and SUPABASE_ANON_KEY via
# --dart-define. Leave empty unless a future approved package explicitly
# authorizes a non-production development setup.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Development project reference.
# Reserved for local tooling/documentation and future approved DEV LINK flows.
# Do not paste production refs.
SUPABASE_PROJECT_REF=

# Feature gates / safety switches.
# These are documentation-aligned safety defaults. They do not activate remote
# backend, real auth, real data or product routing by themselves.
ENABLE_REMOTE_BACKEND=false
ENABLE_REAL_AUTH=false
ENABLE_REAL_DATA=false
ENABLE_CONVERSATIONS_ROUTE=false

# Local/demo safety.
ALLOW_SYNTHETIC_DATA=true
ALLOW_DEV_ROUTES=true

# Logging safety.
LOG_LEVEL=debug
LOG_TOKENS=false
LOG_AUTHORIZATION=false
LOG_REFRESH_TOKENS=false

# Optional current code variables.
# Keep empty/safe unless explicitly configured for local development.
SENTRY_DSN=
PROCESSING_BACKEND_URL=http://localhost:8000
PRODUCTION=false
