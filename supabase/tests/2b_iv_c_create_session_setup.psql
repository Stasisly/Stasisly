\set ON_ERROR_STOP on

do $$
begin
  if exists (
    select 1 from public.specialists where name like 'test_only_2b_iv_c%'
  ) or exists (
    select 1 from public.chat_sessions
    where id::text like '4c400000-0000-4000-8000-%'
  ) then
    raise exception '2B-IV-C fixtures already exist';
  end if;
end
$$;

