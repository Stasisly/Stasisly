\set ON_ERROR_STOP on

do $$
begin
  if exists (select 1 from public.specialists where name like 'test_only_2b_v_c2%')
    or exists (select 1 from public.specialist_catalog where display_name like 'test_only_2b_v_c2%')
    or exists (select 1 from public.chat_sessions where specialist_id::text like '5c200000-0000-4000-8000-%')
  then
    raise exception '2B-V-C2 fixtures already exist';
  end if;
end
$$;

insert into public.specialists (
  id, name, category, prompt_template, is_premium, is_active
) values (
  '5c200000-0000-4000-8000-000000000001',
  'test_only_2b_v_c2 specialist',
  'mental',
  '{"marker":"test_only_2b_v_c2"}',
  false,
  true
);

insert into public.specialist_catalog (
  id, specialist_id, display_name, product_area, short_description,
  publication_status, is_published, availability_status, access_tier, sort_order
) values (
  '5c300000-0000-4000-8000-000000000001',
  '5c200000-0000-4000-8000-000000000001',
  'test_only_2b_v_c2 public specialist',
  'wellness',
  'Fixture local no productivo.',
  'published',
  true,
  'available',
  'free',
  1
);
