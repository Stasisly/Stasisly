\set ON_ERROR_STOP on

do $$
begin
  if exists (select 1 from public.specialists where name like 'test_only_2b_iv_d%')
    or exists (select 1 from public.specialist_catalog where display_name like 'test_only_2b_iv_d%')
  then
    raise exception '2B-IV-D fixtures already exist';
  end if;
end
$$;

insert into public.specialists (
  id, name, category, prompt_template, is_premium, is_active
) values
  ('4d200000-0000-4000-8000-000000000001', 'test_only_2b_iv_d_catalogued',
   'mental', '{"marker":"test_only_2b_iv_d"}', false, true),
  ('4d200000-0000-4000-8000-000000000002', 'test_only_2b_iv_d_without_catalog',
   'mental', '{"marker":"test_only_2b_iv_d"}', false, true);

